{
  "name": "mcp-rvtc",
  "version": "1.0.0",
  "description": "MCP Server for RVTC (Registro de Comunicaciones de Servicios VTC) integration with MITMA",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run tests/unit/ tests/contract/",
    "test:unit": "vitest run tests/unit/",
    "test:contract": "vitest run tests/contract/",
    "test:integration": "RVTC_RUN_INTEGRATION_TESTS=true vitest run tests/integration/",
    "test:all": "vitest run",
    "lint": "eslint src/ tests/"
  },
  "keywords": [
    "mcp",
    "rvtc",
    "vtc",
    "mitma",
    "soap",
    "ws-security"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "fast-xml-parser": "^5.4.2",
    "node-forge": "^1.3.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^13.0.0",
    "xml-crypto": "^6.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/node-forge": "^1.3.14",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
